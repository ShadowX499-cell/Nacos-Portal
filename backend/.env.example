# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nacos_user:nacos_pass@localhost:5432/nacos_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (generate a 256-bit secret: openssl rand -hex 32) ────────────────────
JWT_SECRET=replace_me_with_a_256_bit_secret_at_least_32_chars_long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Email (Nodemailer / SendGrid SMTP) ────────────────────────────────────────
# For development use Mailtrap: https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM="NACOS AIFUE <noreply@nacos-aifue.edu.ng>"

# ── Paystack (Phase 3) ────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Fees ──────────────────────────────────────────────────────────────────────
RESULT_SUBSCRIPTION_AMOUNT_KOBO=50000
SCHOOL_FEES_AMOUNT_KOBO=150000

# ── AWS S3 (Phase 2+) ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=nacos-aifue-uploads
AWS_REGION=af-south-1

# ── Biometric (Phase 4 – Desktop Electron only) ───────────────────────────────
BIOMETRIC_ENCRYPTION_KEY=replace_me_with_a_32_byte_aes_key
